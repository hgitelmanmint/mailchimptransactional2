  "keyFeatures": [
    "Send transactional emails via REST API or SMTP",
    "Reusable templates with merge variable substitution",
    "Real-time webhook event streaming (opens, clicks, bounces)",
    "Per-message tracking (opens, clicks, delivery status)",
    "Dedicated IP provisioning and warmup management",
    "Inbound email processing and routing",
    "Scheduled message delivery",
    "Denylist and allowlist management",
    "Version-based API with migration path from v1.0 to v1.3",
    "Transactional SMS via dedicated sending numbers"
  ],
  "publicApiSurface": [
